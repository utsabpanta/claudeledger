{
  "name": "claudeledger",
  "version": "0.1.0",
  "description": "Local-first analytics for your Claude Code session logs — runs fully offline, sends nothing.",
  "keywords": [
    "claude",
    "claude-code",
    "analytics",
    "cli",
    "tokens",
    "cost",
    "offline"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/utsabpanta/claudeledger.git"
  },
  "homepage": "https://github.com/utsabpanta/claudeledger#readme",
  "bugs": {
    "url": "https://github.com/utsabpanta/claudeledger/issues"
  },
  "type": "module",
  "bin": {
    "claudeledger": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.15.1",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm typecheck && pnpm build && pnpm test"
  },
  "dependencies": {
    "chrono-node": "^2.7.7",
    "cli-table3": "^0.6.5",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
